{
  "name": "vscode-smart-terminal",
  "displayName": "Smart Terminal",
  "description": "A modern terminal extension for VSCode with block-based architecture and AI capabilities",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:smart-terminal.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smart-terminal.open",
        "title": "Open Smart Terminal"
      }
    ],
    "keybindings": [
      {
        "command": "smart-terminal.open",
        "key": "ctrl+shift+\u006f",
        "mac": "cmd+shift+\u006f"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "build:webview": "webpack --config webpack.config.js"
  },
  "dependencies": {
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0",
        "xterm-addon-webgl": "^0.16.0"
    },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "mocha": "^10.0.0",
    "@types/mocha": "^10.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.4.4",
    "glob": "^10.3.0"
  }
}